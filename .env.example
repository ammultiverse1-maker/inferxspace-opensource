# ─────────────────────────────────────────────────────────────────────────────
# InferXSpace — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-a-strong-random-secret

# JWT token expiry (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./data/inferx.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/inferx

# ── Redis (optional — enables rate limiting, caching) ─────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Frontend URL (used for OAuth redirects) ───────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Provider API Keys (add at least one) ─────────────────────────────────────

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Groq (ultra-fast inference) — https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# Mistral — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your-mistral-api-key-here

# Together AI — https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-api-key-here

# Custom endpoint (vLLM, Ollama, LM Studio, any OpenAI-compatible server)
# CUSTOM_API_BASE=http://localhost:11434/v1
# CUSTOM_API_KEY=optional-if-your-server-requires-it
# CUSTOM_MODEL_PREFIX=custom/   # models starting with "custom/" route here

# ── OAuth (optional — social login) ───────────────────────────────────────────
# Google: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# GitHub: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ── Free Tier ─────────────────────────────────────────────────────────────────
# Set to "true" to give new users free monthly credits
FREE_TIER_ENABLED=true
FREE_TIER_MONTHLY_TOKENS=1000000

# ── Email (optional — for password reset, notifications) ──────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com
